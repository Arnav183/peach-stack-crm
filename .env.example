# Peach Stack CRM — Environment Variables
# Copy this file to .env and fill in values for local development.
# In production (Railway), set these in the Railway dashboard — never commit real values.

# Required: JWT signing secret — use a long random string (32+ chars)
# Generate one: openssl rand -hex 32
JWT_SECRET=your-long-random-secret-here

# Required: Peach Stack superadmin credentials (set in Railway, never hardcode)
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=your-strong-password-here

# Optional: Set to "true" on first deploy to wipe and re-seed the database.
# Remove this variable immediately after the first successful deploy.
# RESET_DB=true

# Set automatically by Railway — do not set manually in production
# NODE_ENV=production
